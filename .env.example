# ---- LLM / Embeddings (OpenAI) ----
OPENAI_API_KEY=sk-...

# ---- News (Tavily) ----
TAVILY_API_KEY=tvly-...

# ---- Vector store (Qdrant Cloud or self-hosted) ----
# For Qdrant Cloud: https://xyz-abc.cloud.qdrant.io:6333
# For local docker:  http://localhost:6333  (leave QDRANT_API_KEY empty)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Optional overrides ----
# Chat model used by the Analyst & Writer nodes
CHAT_MODEL=gpt-4o
# OpenAI embedding model (1536 dims) — keep in sync with EMBEDDING_DIM in config.py
EMBEDDING_MODEL=text-embedding-3-small

# SEC EDGAR requires a User-Agent in "Name email@domain" format (their fair-access
# policy). Parenthetical or browser-like User-Agents are rejected with HTTP 403.
SEC_USER_AGENT=Your Name your_email@example.com
